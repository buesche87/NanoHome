      "options": {
        "content": "<h3>Schaltuhr</h3>\r\n<hr />\r\n\r\n<select class=\"nanohome\" id=\"timer_device\" onchange=\"cronman('show')\" name=\"nanolist_timer\">\r\n</select>\r\n\r\n<table align=\"center\" style=\"width:100%\">\r\n        <tr>\r\n            <td colspan=\"2\">\r\n\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td align=\"right\" style=\"width:50%\"><font size=\"4\">Ein / Auf</font></td>\r\n            <td align=\"left\" ><input class=\"form\" id=\"timer_ein\" pattern=\".{5,5}\" onfocus=\"this.value=''\" value=\"08:00\" onfocus=\"this.value=''\" onfocusout=\"if (this.value === '') { this.value = this.defaultValue; }\" autocomplete=\"off\" /></td>\r\n        </tr>\r\n        <tr>\r\n            <td align=\"right\"  style=\"width:50%\"><font size=\"4\">Aus / Zu</font></td>\r\n            <td align=\"left\" ><input class=\"form\" id=\"timer_aus\" pattern=\".{5,5}\" onfocus=\"this.value=''\" value=\"22:00\" onfocus=\"this.value=''\" onfocusout=\"if (this.value === '') { this.value = this.defaultValue; }\" autocomplete=\"off\" /></td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"2\" align=\"center\">\r\n                <select class=\"form\" id=\"timer_day\">\r\n                    <option value=\"*\">Täglich</option>\r\n                    <option value=\"1\">Montag</option>\r\n                    <option value=\"2\">Dienstag</option>\r\n                    <option value=\"3\">Mittwoch</option>\r\n                    <option value=\"4\">Donnerstag</option>\r\n                    <option value=\"5\">Freitag</option>\r\n                    <option value=\"6\">Samstag</option>\r\n                    <option value=\"0\">Sonntag</option>\r\n                    <option value=\"6-7\">Wochenende</option>\r\n                    <option value=\"1-5\">Werktags</option>\r\n                </select>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td colspan=\"2\" align=\"center\">\r\n                <button title=\"Schaltuhr aktivieren\" class=\"form\" style=\"background-color: #adfc95\" onclick=\"cronman('add')\">💾</button>\r\n                <button title=\"Alle Schaltuhren zeigen\" class=\"form\" style=\"background-color: #fff4bd\" onclick=\"cronman('show all')\">🔎</button>\r\n                <button title=\"Schaltuhr deaktivieren\" class=\"form\" style=\"background-color: #ffbdbd\" onclick=\"cronman('remove')\">❌</button>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n</div>\r\n\r\n<script>\r\n\r\n\tfunction cronman(param) {\r\n\t\r\n        var zsp_dev = document.getElementById(\"timer_device\").value;\r\n        var zsp_tag = document.getElementById(\"timer_day\").value;\r\n        var zsp_ein = document.getElementById(\"timer_ein\").value;\r\n        var zsp_aus = document.getElementById(\"timer_aus\").value;\r\n\r\n        var zsp_message = \"cronman \" + param + \" '\" + zsp_dev + \"' '\" + zsp_tag + \"' '\" + zsp_ein + \"' '\" + zsp_aus + \"'\";\r\n\t\r\n        publish_timer(zsp_message);\r\n\t\t    \r\n\t};\r\n\r\n</script>\r\n\r\n",
        "mode": "html"
      },
      "pluginVersion": "7.3.3",
      "timeFrom": null,
