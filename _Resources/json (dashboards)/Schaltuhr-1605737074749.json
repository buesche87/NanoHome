      "options": {
        "content": "<h3>Multiswitch</h3>\r\n<hr />\r\n\r\n<center>\r\n\r\n<select class=\"nanohome\" id=\"multi_dev1\" onchange=\"multiswitch('show')\" name=\"nanolist_multiswitch\">\r\n\t<option selected disabled>Wenn...</option>\r\n</select>\r\n\r\n</p>\r\n\r\n<select class=\"form\" id=\"multi_value1\" onchange=\"multiswitch('show')\">\r\n    <option value=\"on\">Ein</option>\r\n    <option value=\"off\">Aus</option>\r\n    <option disabled>-------</option>\r\n    <option value=\"on\">Auf</option>\r\n    <option value=\"off\">Zu</option>\r\n</select>\r\n\r\n</p>\r\n\r\n<select class=\"nanohome\" id=\"multi_dev2\" onchange=\"multiswitch('show')\" name=\"nanolist\">\r\n\t<option selected disabled>Dann...</option>\r\n</select>\r\n\r\n</p>\r\n\r\n<select class=\"form\" id=\"multi_value2\" onchange=\"multiswitch('show')\">\r\n    <option value=\"on\">Ein</option>\r\n    <option value=\"off\">Aus</option>\r\n    <option disabled>-------</option>\r\n    <option value=\"on\">Auf</option>\r\n    <option value=\"off\">Zu</option>\r\n</select>\r\n\r\n</p>\r\n\r\n<select class=\"form\" id=\"multi_day\" onchange=\"show_time()\">\r\n    <option selected disabled>Aktiv...</option>\r\n    <option value=\"always\">Immer</option>\r\n    <option value=\"*\">Täglich</option>\r\n    <option value=\"1\">Montag</option>\r\n    <option value=\"2\">Dienstag</option>\r\n    <option value=\"3\">Mittwoch</option>\r\n    <option value=\"4\">Donnerstag</option>\r\n    <option value=\"5\">Freitag</option>\r\n    <option value=\"6\">Samstag</option>\r\n    <option value=\"0\">Sonntag</option>\r\n    <option value=\"6-7\">Wochenende</option>\r\n    <option value=\"1-5\">Werktags</option>\r\n</select>\r\n\r\n</p>\r\n\r\n<input class=\"form\" id=\"multi_on\" pattern=\".{5,5}\" value=\"-\" onfocus=\"this.value=''\" onfocusout=\"if (this.value === '') { this.value = this.defaultValue; }\" autocomplete=\"off\" />\r\n<font size=\"4\">-</font>\r\n<input class=\"form\" id=\"multi_off\" pattern=\".{5,5}\" value=\"-\" onfocus=\"this.value=''\" onfocusout=\"if (this.value === '') { this.value = this.defaultValue; }\" autocomplete=\"off\" />\r\n\r\n</p>\r\n\r\n<button title=\"Aktivieren\" class=\"form\" style=\"background-color: #adfc95\" onclick=\"multiswitch('add')\">💾</button>\r\n<button title=\"Alle Anzeigen\" class=\"form\" style=\"background-color: #fff4bd\" onclick=\"multiswitch('show all')\">🔎</button>\r\n<button title=\"Deaktivieren\" class=\"form\" style=\"background-color: #ffbdbd\" onclick=\"multiswitch('remove')\">❌</button>\r\n\r\n</p>\r\n\r\n</center>\r\n\r\n<script>\r\n\r\n    function multiswitch(param) {\r\n        var multi_dev1 = document.getElementById(\"multi_dev1\").value;\r\n        var multi_dev2 = document.getElementById(\"multi_dev2\").value;\r\n        var multi_value1 = document.getElementById(\"multi_value1\").value;\r\n        var multi_value2 = document.getElementById(\"multi_value2\").value;\r\n        var multi_day = document.getElementById(\"multi_day\").value;\r\n        var multi_on = document.getElementById(\"multi_on\").value;\r\n        var multi_off = document.getElementById(\"multi_off\").value;\r\n\r\n        var multiswitch_message = \"multiswitch \" + param + \" '\" + multi_dev1 + \"' '\" + multi_dev2 + \"' '\" + multi_value1 + \"' '\" + multi_value2 + \"' '\" + multi_day + \"' '\" + multi_on + \"' '\" + multi_off + \"'\";\r\n\r\n        publish_timer(multiswitch_message);\r\n\r\n    }\r\n\r\n    function show_time() {\r\n      \r\n        var multi_day = document.getElementById(\"multi_day\");\r\n\r\n        if (multi_day.value !== \"always\") {\r\n          \r\n            document.getElementById(\"multi_on\").value = \"08:00\";\r\n            document.getElementById(\"multi_off\").value = \"22:00\";\r\n            \r\n        } else {\r\n          \r\n            document.getElementById(\"multi_on\").value = \"-\";\r\n            document.getElementById(\"multi_off\").value = \"-\";\r\n            \r\n        }\r\n    }\r\n\r\n</script>\r\n",
