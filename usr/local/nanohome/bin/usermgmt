#!/bin/bash
# usermgmt - Manages MQTT devices on Grafana Dashboards

if [ -z "$1" ]; then
	
	echo "-------------------------------------------------"
	echo "Usage: usermgmt show|add|remove username password"
	echo "-------------------------------------------------"
	echo

	exit 1
fi

# Parameter
user="$2"
pwd="$3"

# Settings
pwdfile="/etc/mosquitto/passwd"

# Functions
show_users () {
	
	list=$(cat /etc/mosquitto/passwd | cut -d : -f 1 | grep -v cron_mqtt | grep -v mqtt_shell | grep -v multiswitch_mqtt | grep -v mqtt_bridge | grep -v mqtt_grafana)
	
	statusmsg "MQTT-Benutzerliste" "white" "" "" "" "" "$list" "hotpink"
	
}

err_exit () {
	
	statusmsg "Error" "red" "" "" "" "" "Zu wenig Parameter definiert \nUsage: usermgmt show|add|remove username password" "white"
	
	exit 1

}

if [ "$1" = "show" ]; then
	
	show_users

fi

if [ "$1" = "add" ]; then

	if [ -z "$2" ] || [ -z "$3" ]; then
	
		err_exit
	fi
	
	mosquitto_passwd -b /etc/mosquitto/passwd "$user" "$pwd"
	
	show_users

fi

if [ "$1" = "remove" ]; then

	if [ -z "$2" ]; then
	
		err_exit
	fi
	
	mosquitto_passwd -D /etc/mosquitto/passwd "$user"
	
	show_users

fi

