#!/bin/bash
#/////////////////////////////////////////////////////////////////////////////////////
# Modified autohotspot script from RaspberryConnect.com 
#/////////////////////////////////////////////////////////////////////////////////////

# Settings
wifidev="wlan0"

#use the command: iw dev ,to see wifi interface name 

IFSdef=$IFS
cnt=0
#These four lines capture the wifi networks the RPi is setup to use
wpassid=$(awk '/ssid="/{ print $0 }' /etc/wpa_supplicant/wpa_supplicant.conf | awk -F'ssid=' '{ print $2 }' ORS=',' | sed 's/\"/''/g' | sed 's/,$//')
IFS=","
ssids=($wpassid)
IFS=$IFSdef #reset back to defaults

#Enter the Routers Mac Addresses for hidden SSIDs, seperated by spaces ie 
#( '11:22:33:44:55:66' 'aa:bb:cc:dd:ee:ff' ) 
mac=()

ssidsmac=("${ssids[@]}" "${mac[@]}") #combines ssid and MAC for checking


#/////////////////////////////////////////////////////////////////////////////////////
# Create Hotspot
#/////////////////////////////////////////////////////////////////////////////////////
createAdHocNetwork()
{

	ip link set dev "$wifidev" down
	wpa_cli terminate >/dev/null 2>&1
	ip addr flush "$wifidev"  
	rm -r /var/run/wpa_supplicant >/dev/null 2>&1
	
	echo "[$(date +'%H:%m:%S')] Wifi disconnected" >> /var/log/autohotspot.log
	
	ip a add 10.0.0.5/24 brd + dev "$wifidev"
	ip link set dev "$wifidev" up
	
	systemctl unmask dnsmasq hostapd
	systemctl start dnsmasq hostapd
	
	echo "[$(date +'%H:%m:%S')] Hotspot created" >> /var/log/autohotspot.log
  
}

#/////////////////////////////////////////////////////////////////////////////////////
# Kill Hotspot
#/////////////////////////////////////////////////////////////////////////////////////
KillHotspot()
{

	echo "[$(date +'%H:%m:%S')] Shutting Down Hotspot" >> /var/log/autohotspot.log
	ip link set dev "$wifidev" down
	
	systemctl stop hostapd dnsmasq
	systemctl mask dnsmasq hostapd
	
	ip addr flush dev "$wifidev"

}

#/////////////////////////////////////////////////////////////////////////////////////
# Check if Wifi is up
#/////////////////////////////////////////////////////////////////////////////////////
ChkWifiUp()
{

	echo "[$(date +'%H:%m:%S')] Checking WiFi connection with $ssidChk" >> /var/log/autohotspot.log
	
	sleep 5
	
	checkwifi="$(iw $wifidev link | grep 'Connected to' | wc -l)"
	
	if [ $checkwifi -eq 0 ]; then
		echo "[$(date +'%H:%m:%S')] Wifi failed to connect, falling back to Hotspot." >> /var/log/autohotspot.log
		createAdHocNetwork
	else
		echo "[$(date +'%H:%m:%S')] Connected to $ssidChk" >> /var/log/autohotspot.log
		ntpdate -u ch.pool.ntp.org
		
		if grep static /etc/network/interfaces; then 
			pkill -f "dhclient"
		fi
	fi

}

#/////////////////////////////////////////////////////////////////////////////////////
# Connect to Wifi
#/////////////////////////////////////////////////////////////////////////////////////
function connect_wifi {

	ip link set dev "$wifidev" up
	wpa_supplicant -B -i "$wifidev" -c /etc/wpa_supplicant/wpa_supplicant.conf >/dev/null 2>&1

	if grep dhcp /etc/network/interfaces; then 
		dhclient "$wifidev"
	fi

	echo "[$(date +'%H:%m:%S')] Wifi connected" >> /var/log/autohotspot.log
	
}

#/////////////////////////////////////////////////////////////////////////////////////
# Disconnect Wifi
#/////////////////////////////////////////////////////////////////////////////////////
function disconnect_wifi {

	ip link set dev "$wifidev" down
	wpa_cli terminate >/dev/null 2>&1
	ip addr flush "$wifidev"
	rm -r /var/run/wpa_supplicant >/dev/null 2>&1
	echo "[$(date +'%H:%m:%S')] Wifi disconnected" >> /var/log/wmod.log
	
}

#/////////////////////////////////////////////////////////////////////////////////////
# Find SSIDs in Range
#/////////////////////////////////////////////////////////////////////////////////////
FindSSID()
{
  #Check to see what SSID's
  ssidChk=('NoSSid')
  i=0; j=0

  until [ $i -eq 1 ] ; do #wait for wifi if busy, usb wifi is slower.
    ssidreply=$((iw dev "$wifidev" scan ap-force | egrep "^BSS|SSID:") 2>&1) >/dev/null 2>&1 
    echo "[$(date +'%H:%m:%S')] SSid's in range: " $ssidreply >> /var/log/autohotspot.log
    echo "[$(date +'%H:%m:%S')] Device Available Check try " $j >> /var/log/autohotspot.log

    if (($j >= 10)); then #if busy 10 times goto hotspot
      echo "[$(date +'%H:%m:%S')] Device busy or unavailable 10 times, going to Hotspot" >> /var/log/autohotspot.log
      ssidreply=""
      i=1
      sleep 1

    elif echo "$ssidreply" | grep "No such device (-19)" >/dev/null 2>&1; then
      echo "[$(date +'%H:%m:%S')] No Device Reported, try " $j >> /var/log/autohotspot.log
      NoDevice

    elif echo "$ssidreply" | grep "Network is down (-100)" >/dev/null 2>&1 ; then
      echo "[$(date +'%H:%m:%S')] Network Not available, trying again" $j >> /var/log/autohotspot.log

      if (($j == 1)); then # try bringing up wlan0 once
		ip link set dev "$wifidev" up
      fi

      j=$((j + 1))
      sleep 2

    elif echo "$ssidreplay" | grep "Read-only file system (-30)" >/dev/null 2>&1 ; then
      echo "[$(date +'%H:%m:%S')] Temporary Read only file system, trying again" >> /var/log/autohotspot.log
      j=$((j + 1))
      sleep 2

    elif ! echo "$ssidreply" | grep "resource busy (-16)" >/dev/null 2>&1 ; then
      echo "[$(date +'%H:%m:%S')] Device Available, checking SSid Results" >> /var/log/autohotspot.log
      i=1

    else #see if device not busy in 2 seconds
      echo "[$(date +'%H:%m:%S')] Device unavailable checking again, try " $j >> /var/log/autohotspot.log
      j=$((j + 1))
      sleep 2
    fi
  done

  for ssid in "${ssidsmac[@]}" ; do
    if (echo "$ssidreply" | grep "$ssid") >/dev/null 2>&1 ; then #Valid SSid found, passing to script
      echo "[$(date +'%H:%m:%S')] Valid SSID Detected, assesing Wifi status" >> /var/log/autohotspot.log
      ssidChk=$ssid
      return 0
    else #No Network found, NoSSid issued"
      echo "[$(date +'%H:%m:%S')] No SSID found, assessing WiFi status" >> /var/log/autohotspot.log
      ssidChk='NoSSid'
    fi
  done
}

#/////////////////////////////////////////////////////////////////////////////////////
# No Wifi Device
#/////////////////////////////////////////////////////////////////////////////////////
NoDevice()
{
  #if no wifi device,ie usb wifi removed, activate wifi so when it is
  #reconnected wifi to a router will be available
  echo "[$(date +'%H:%m:%S')] No wifi device connected" >> /var/log/autohotspot.log
  wpa_supplicant -B -i "$wifidev" -c /etc/wpa_supplicant/wpa_supplicant.conf >/dev/null 2>&1
  exit 1
}

#/////////////////////////////////////////////////////////////////////////////////////
# Main
#/////////////////////////////////////////////////////////////////////////////////////

FindSSID

#Create Hotspot or connect to valid wifi networks
if [ "$ssidChk" != "NoSSid" ] ; then
  if systemctl status hostapd | grep "(running)" >/dev/null 2>&1 ; then #hotspot running and ssid in range
  
    KillHotspot
	echo "[$(date +'%H:%m:%S')] Hotspot Deactivated, Bringing Wifi Up" >> /var/log/autohotspot.log
	connect_wifi
	echo "[$(date +'%H:%m:%S')] Connecting to Wifi" >> /var/log/autohotspot.log
	ChkWifiUp

  elif { wpa_cli -i "$wifidev" status | grep 'ip_address'; } >/dev/null 2>&1 ; then #Already connected

    echo "[$(date +'%H:%m:%S')] Wifi already connected to a network" >> /var/log/autohotspot.log

  else #ssid exists and no hotspot running connect to wifi network

    echo "[$(date +'%H:%m:%S')] Connecting to the WiFi Network" >> /var/log/autohotspot.log
	connect_wifi
	ChkWifiUp

  fi

else #ssid or MAC address not in range
    if systemctl status hostapd | grep "(running)" >/dev/null 2>&1 ; then

      echo "[$(date +'%H:%m:%S')] Hostspot already active" >> /var/log/autohotspot.log

    elif { wpa_cli status | grep "$wifidev"; } >/dev/null 2>&1 ; then
		
	  echo "[$(date +'%H:%m:%S')] Wifi running, activating Hotspot" >> /var/log/autohotspot.log
	  disconnect_wifi
      createAdHocNetwork

    else

	   echo "[$(date +'%H:%m:%S')] No SSID, activating hotspot" >> /var/log/autohotspot.log
       createAdHocNetwork

    fi
fi
