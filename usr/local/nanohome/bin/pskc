#!/bin/bash
## A simple `wifi` command for Debian that will add a new WPA2 WiFi network
## usage:
## sudo ./pskc <psk>

new_psk="$1"

if [ ! -z "$1" ] && [ ! "$new_psk" = "NanoHome WLAN Key" ]; then

	statusmsg "Aktualisiere NanoHome WLAN Key" "white" "" "" "Zum Verbinden mit dem NanoGate \nNanoHome neu starten oder WLAN Modus umstellen" "white"

    sed -i "s/wpa_passphrase=.*/wpa_passphrase="$new_psk"/"  /etc/hostapd/hostapd.conf
	sed -i "s/psk=.*/psk="\""$new_psk""\"/"  /etc/wpa_supplicant/wpa_supplicant.conf.nanogate
	systemctl is-active --quiet hostapd && systemctl restart hostapd

else

	errmsg "Error" "Eingabe prüfen" 

fi
