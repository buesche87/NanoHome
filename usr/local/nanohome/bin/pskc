#!/bin/bash
## A simple `wifi` command for Debian that will add a new WPA2 WiFi network
## usage:
## sudo ./pskc <psk>

new_psk="$1"

echo
echo "[ KEY: $new_psk ]"
echo

if [ -z "$1" ]; then
    echo "--------------------------"
    echo "Keine Parameter definiert"
    echo "Usage: pskc 'PSK'"
    echo "--------------------------"

else
    echo
    echo "... aktualisiere NanoHome WIFI Key"
    echo
    sed -i "s/wpa_passphrase=.*/wpa_passphrase="\""$new_psk""\"/"  /etc/hostapd/hostapd.conf
    echo "... Restarting Hotspot"
    systemctl restart hostapd
fi