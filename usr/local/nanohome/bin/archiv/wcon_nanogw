#!/bin/bash
## A simple `wifi` command for Debian that will add a new WPA2 WiFi network
## usage:
## sudo ./wcon_nanogw <psk>

new_psk=$1

echo
echo "[ KEY: $new_psk ]"
echo

if [ -z "$1" ]
  then
    echo "------------------------------------------"
    echo "Keine Parameter definiert"
    echo "Usage: wcon_nanogw 'PSK' ('IP') ('Subnet')"
    echo "------------------------------------------"
  else
    echo
    echo "... aktualisiere NanoGateway WLAN"
    echo
    sed -i "s/psk=.*/psk="\""$new_psk""\"/"  /etc/wpa_supplicant/wpa_supplicant.conf.nanogateway
fi