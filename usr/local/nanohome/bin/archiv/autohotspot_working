#!/bin/bash
#version 0.95-4-N/HS

#You may share this script on the condition a reference to RaspberryConnect.com 
#must be included in copies or derivatives of this script. 

#A script to switch between a wifi network and a non internet routed Hotspot
#Works at startup or with a seperate timer or manually without a reboot
#Other setup required find out more at
#http://www.raspberryconnect.com

wifidev="wlan0" #device name to use. Default is wlan0.

#use the command: iw dev ,to see wifi interface name 

IFSdef=$IFS
cnt=0
#These four lines capture the wifi networks the RPi is setup to use
wpassid=$(awk '/ssid="/{ print $0 }' /etc/wpa_supplicant/wpa_supplicant.conf | awk -F'ssid=' '{ print $2 }' ORS=',' | sed 's/\"/''/g' | sed 's/,$//')
IFS=","
ssids=($wpassid)
IFS=$IFSdef #reset back to defaults


#Note:If you only want to check for certain SSIDs
#Remove the # in in front of ssids=('mySSID1'.... below and put a # infront of all four lines above
# separated by a space, eg ('mySSID1' 'mySSID2')
#ssids=('mySSID1' 'mySSID2' 'mySSID3')

#Enter the Routers Mac Addresses for hidden SSIDs, seperated by spaces ie 
#( '11:22:33:44:55:66' 'aa:bb:cc:dd:ee:ff' ) 
mac=()

ssidsmac=("${ssids[@]}" "${mac[@]}") #combines ssid and MAC for checking

createAdHocNetwork()
{
  ifdown "$wifidev"
  wpa_cli terminate >/dev/null 2>&1
  ip addr flush "$wifidev"
  rm -r /var/run/wpa_supplicant >/dev/null 2>&1
  ip a add 10.0.0.5/24 brd + dev "$wifidev"
  ip link set dev "$wifidev" up
  systemctl unmask dnsmasq hostapd
  systemctl start dnsmasq hostapd
  echo "Hotspot created" >> /var/log/autohotspot.log
}

KillHotspot()
{
  echo "Shutting Down Hotspot" >> /var/log/autohotspot.log
  ifdown "$wifidev"
  systemctl stop hostapd dnsmasq
  systemctl mask dnsmasq hostapd
  echo "Hotspot down" >> /var/log/autohotspot.log
  ip addr flush dev "$wifidev"
}

ChkWifiUp()
{
  echo "Checking WiFi connection ok" >> /var/log/autohotspot.log
  sleep 5 #give time for connection to be completed to router

  checkwifi='iw "$wifidev" link | grep $ssidChk | wc -l'
  
  if [ $checkwifi -eq 0 ]; then # not connected, back to hotspott
	echo 'Wifi failed to connect, falling back to Hotspot.' >> /var/log/autohotspot.log
    createAdHocNetwork
  else
	echo "Connected to $ssidChk" >> /var/log/autohotspot.log
  fi

}


FindSSID()
{
  #Check to see what SSID's
  ssidChk=('NoSSid')
  i=0; j=0

  until [ $i -eq 1 ] ; do #wait for wifi if busy, usb wifi is slower.
    ssidreply=$((iw dev "$wifidev" scan ap-force | egrep "^BSS|SSID:") 2>&1) >/dev/null 2>&1 
    echo "SSid's in range: " $ssidreply >> /var/log/autohotspot.log
    echo "Device Available Check try " $j >> /var/log/autohotspot.log

    if (($j >= 10)); then #if busy 10 times goto hotspot
      echo "Device busy or unavailable 10 times, going to Hotspot" >> /var/log/autohotspot.log
      ssidreply=""
      i=1
      # sleep 1

    elif echo "$ssidreply" | grep "No such device (-19)" >/dev/null 2>&1; then
      echo "No Device Reported, try " $j >> /var/log/autohotspot.log
      NoDevice

    elif echo "$ssidreply" | grep "Network is down (-100)" >/dev/null 2>&1 ; then
      echo "Network Not available, trying again" $j >> /var/log/autohotspot.log

      if (($j == 1)); then # try bringing up wlan0 once
        ifup "$wifidev"
      fi

      j=$((j + 1))
      # sleep 2

    elif echo "$ssidreplay" | grep "Read-only file system (-30)" >/dev/null 2>&1 ; then
      echo "Temporary Read only file system, trying again" >> /var/log/autohotspot.log
      j=$((j + 1))
      # sleep 2

    elif ! echo "$ssidreply" | grep "resource busy (-16)" >/dev/null 2>&1 ; then
      echo "Device Available, checking SSid Results" >> /var/log/autohotspot.log
      i=1

    else #see if device not busy in 2 seconds
      echo "Device unavailable checking again, try " $j >> /var/log/autohotspot.log
      j=$((j + 1))
      # sleep 2
    fi
  done

  for ssid in "${ssidsmac[@]}" ; do
    if (echo "$ssidreply" | grep "$ssid") >/dev/null 2>&1 ; then #Valid SSid found, passing to script
      echo "Valid SSID Detected, assesing Wifi status" >> /var/log/autohotspot.log
      ssidChk=$ssid
      return 0
    else #No Network found, NoSSid issued"
      echo "No SSID found, assessing WiFi status" >> /var/log/autohotspot.log
      ssidChk='NoSSid'
    fi
  done
}

NoDevice()
{
  #if no wifi device,ie usb wifi removed, activate wifi so when it is
  #reconnected wifi to a router will be available
  echo "No wifi device connected" >> /var/log/autohotspot.log
  wpa_supplicant -B -i "$wifidev" -c /etc/wpa_supplicant/wpa_supplicant.conf >/dev/null 2>&1
  exit 1
}

FindSSID

#Create Hotspot or connect to valid wifi networks
if [ "$ssidChk" != "NoSSid" ] ; then
  if systemctl status hostapd | grep "(running)" >/dev/null 2>&1 ; then #hotspot running and ssid in range
    KillHotspot
    echo "Hotspot Deactivated, Bringing Wifi Up" >> /var/log/autohotspot.log
    ifup "$wifidev"
	# dhclient "$wifidev"
    ChkWifiUp
  elif { wpa_cli -i "$wifidev" status | grep 'ip_address'; } >/dev/null 2>&1 ; then #Already connected
    echo "Wifi already connected to a network" >> /var/log/autohotspot.log
  else #ssid exists and no hotspot running connect to wifi network
    echo "Connecting to the WiFi Network" >> /var/log/autohotspot.log
    ifup "$wifidev"
    # dhclient "$wifidev"
	ChkWifiUp
  fi

else #ssid or MAC address not in range
    if systemctl status hostapd | grep "(running)" >/dev/null 2>&1 ; then
      echo "Hostspot already active" >> /var/log/autohotspot.log
    elif { wpa_cli status | grep "$wifidev"; } >/dev/null 2>&1 ; then
      echo "Cleaning wifi files and Activating Hotspot" >> /var/log/autohotspot.log
      ifdown "$wifidev"
      wpa_cli terminate >/dev/null 2>&1
      ip addr flush "$wifidev"
      rm -r /var/run/wpa_supplicant >/dev/null 2>&1
      createAdHocNetwork
    else #"No SSID, activating Hotspot"
		echo "No SSID, activating hotspot" >> /var/log/autohotspot.log
       createAdHocNetwork
    fi
fi
