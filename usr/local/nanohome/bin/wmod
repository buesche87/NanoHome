#!/bin/bash
# Script to change Wifi Mode

wifidev="wlan0" #device name to use. Default is wlan0. 

if [ -z "$1" ]
  then
    echo "-------------------------"
    echo "Keine Parameter definiert"
    echo "Usage: wmod -mode"
    echo "-------------------------"
	exit 1
fi

function create_hotspot {
	ifdown "$wifidev"
	wpa_cli terminate >/dev/null 2>&1
	ip addr flush "$wifidev"
	rm -r /var/run/wpa_supplicant >/dev/null 2>&1
	ip a add 10.0.0.5/24 brd + dev "$wifidev"
	ip link set dev "$wifidev" up
	systemctl unmask dnsmasq
	systemctl unmask hostapd
	systemctl start dnsmasq
	systemctl start hostapd
	ip_to_mqtt
	echo "Hotspot created"
	}

function shutdown_hotspot {
	if systemctl status hostapd | grep "(running)" >/dev/null 2>&1
	  then # Shutting Down Hotspot
		systemctl stop hostapd
		systemctl stop dnsmasq
		systemctl mask dnsmasq
		systemctl mask hostapd
		echo "Hotspot down"
	
	fi
	}

function connect_wifi {
	ifdown "$wifidev"
	cp /etc/wpa_supplicant/wpa_supplicant.conf.$1 /etc/wpa_supplicant/wpa_supplicant.conf
	ip addr flush dev "$wifidev"
	ifup "$wifidev"
	dhcpcd -n "$wifidev" >/dev/null 2>&1
	ip_to_mqtt
	echo "Wifi connected"
	}

function backup_config {
	echo "Backup Config"
	if cat /etc/wpa_supplicant/wpa_supplicant.conf | grep "NanoGateway"; then
		cp /etc/wpa_supplicant/wpa_supplicant.conf /etc/wpa_supplicant/wpa_supplicant.conf.nanogateway
	else
		cp /etc/wpa_supplicant/wpa_supplicant.conf /etc/wpa_supplicant/wpa_supplicant.conf.wificlient
	fi
	}

if [ "$1" = "-wificlient" ]; then
	echo "Wifi Client"
		
	backup_config
	shutdown_hotspot
	connect_wifi wificlient
	
	if { wpa_cli -i "$wifidev" status | grep 'ip_address'; } > /dev/null 2>&1
	  then
	    echo "Verbunden"
	else
		echo "Create Hotspot"
		# create_hotspot
	fi

elif [ "$1" = "-nanogw" ]; then
	echo "NanoGateway"
	
	backup_config 
	shutdown_hotspot
	connect_wifi nanogateway
	
	sleep 5
	
	if { wpa_cli -i "$wifidev" status | grep 'ssid=NanoGateway'; } >/dev/null 2>&1
	  then
	    echo "Verbunden"
	else
		echo "Create Hotspot"
		create_hotspot
	fi

elif  [ "$1" = "-hotspot" ]; then
	echo "Hotspot"
	
	if { wpa_cli status | grep "$wifidev"; } >/dev/null 2>&1
	  then
		create_hotspot
	fi

else
	echo "Falscher Parameter"
	echo "Usage: wmod -mode [wificlient hotspot nanogw]"
fi


