#!/bin/bash
# nanobackup - NanoHome backup tool

# dgt backup parameters  
rectype="$1" #[backup|restore]
grafana="$2" #[true|false]
influxdb="$3" #[true|false]
wifi="$4" #[true|false]

# settings
backupdir="/mnt/recovery_sd/root/Backup"
bkdr_grafana="$backupdir/Grafana"
bkdr_influxdb="$backupdir/InfluxDB"
bkdr_wifi="$backupdir/wpa_supplicant/"
install_dir="/usr/local/nanohome/"

# mount recovery-sd
umount /mnt/recovery_sd >> /dev/null 2>&1
mount -t auto -v /dev/mmcblk1p2 /mnt/recovery_sd >> /dev/null 2>&1

if [ ! $? -eq 0 ]; then

  echo "recovery-sd not found"
  echo "trying to different sd card"
  mount -t auto -v /dev/mmcblk1p1 /mnt/recovery_sd >> /dev/null 2>&1
  
  if [ $? -eq 0 ]; then

    echo "sd mounted"
	echo ""

  else
 
     echo "no sd card found" 
     exit 1
  fi
  
fi

# create directories
if [ ! -d "$backupdir" ]; then

    mkdir -p "$bkdr_grafana"
    mkdir -p "$bkdr_influxdb"
    mkdir -p "bkdr_wifi"

fi

# get backup selections from interface
if [ "$rectype" == "backup" ]; then

    if [ "$grafana" == "true" ]; then
        cd $install_dir/grafana-backup-tool/
        ./backup_grafana.sh "$bkdr_grafana" >> /dev/null 2>&1
        touch "$bkdr_grafana"
        echo "Grafana Backup..."
    fi
    if [ "$influxdb" == "true" ]; then
        influxd backup -portable -database NanoPi "$bkdr_influxdb" >> /dev/null 2>&1
        touch "$bkdr_influxdb"
        echo "InfluxDB Backup..."
    fi
    if [ "$wifi" == "true" ]; then
        cp -R /etc/wpa_supplicant/wpa-supplicant* "$bkdr_wifi" >> /dev/null 2>&1
        echo "Wifi Backup..."
        touch "$bkdr_wifi"
    fi

	echo "<br><font size=5 color='hotpink'>Backup complete</font>"

fi

# get restore selections from interface
if [ "$rectype" == "restore" ]; then

    if [ "$grafana" == "true" ]; then
        echo "Restoring Grafana..."
        #cd /root/grafana-backup-tool/
        #./restore_grafana.sh
    fi
    if [ "$influxdb" == "true" ]; then
        echo "Restoring InfluxDB..."
        #influxd restore -portable /mnt/recovery_sd/root/Backup/InfluxDB
    fi

    if [ "$wifi" == "true" ]; then
        echo "Restoring Wifi Settings..."
        #cp /mnt/recovery_sd/root/Backup/wpa_supplicant/* /etc/wpa_supplicant/
    fi
	
	echo "<br><font size=5 color='hotpink'>Restore complete (deaktiviert)</font>"
	
fi

# show backups
if [ "$rectype" == "show" ]; then

	echo "<font size=5 color='hotpink'>Stored Backups</font><br>"
	echo "$(tree -d -D --timefmt "%d.%m.%y %T" /mnt/recovery_sd/root/Backup)"

fi

# unmount sd card
umount /mnt/recovery_sd >> /dev/null 2>&1
