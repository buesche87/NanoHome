#!/bin/bash
# multiswitch - Sends value to Topic if device sends value

if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then

	echo "----------------------------------------------------------"
	echo "Usage: multiswitch show|add|remove dev1 dev2 value1 value2"
	echo "----------------------------------------------------------"
	echo

	exit 1
fi

# settings
server="localhost"
user="multiswitch_mqtt"
pass="MULTISWITCH2MQTT"

# parameters
dev1="$2"
dev2="$3"
value1="$4"
value2="$5"

# device support
. /usr/local/nanohome/dev_compatibility $dev1
dev1_power_topic=$(echo $power_topic)
. /usr/local/nanohome/dev_compatibility $dev2
dev2_control_topic=$(echo $control_topic)
desc_dev1=$(cat /usr/local/nanohome/devlist | grep $dev1 | cut -d: -f2 )
desc_dev2=$(cat /usr/local/nanohome/devlist | grep $dev2 | cut -d: -f2 )

# environment
service_name="multiswitch.$dev1.$value1-$dev2.$value2.service"
service_file="/etc/systemd/system/$service_name"
service_template="/usr/local/nanohome/templates/multiswitch.service.template"


# show multiswitch
if [ "$1" = "show" ]; then

	if [ "$dev1" = "$dev2" ]; then

		#-------- To be done ---------#
		active="$(ls /etc/systemd/system/ | grep multiswitch )"
		
		if [ ! -z "$active" ]; then
		
			echo "<font size='6' color='white'>Multiswitch - </font><font size='6' color='green'>Aktiv:</font><br>"
		
			while IFS= read -r line
			do
				
				dev1="$(cat /etc/systemd/system/$line | grep multiswitch | awk '{ printf $4 }' )"
				dev2="$(cat /etc/systemd/system/$line | grep multiswitch | awk '{ printf $5 }' )"
				val1="$(cat /etc/systemd/system/$line | grep multiswitch | awk '{ printf $6 }' )"
				val2="$(cat /etc/systemd/system/$line | grep multiswitch | awk '{ printf $7 }' )"
				
				desc_dev1=$(cat /usr/local/nanohome/devlist | grep $dev1 | cut -d: -f2 )
				desc_dev2=$(cat /usr/local/nanohome/devlist | grep $dev2 | cut -d: -f2 )
				
				echo "<font color='hotpink'>$desc_dev2</font> [$val2] <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> [$val1]"
				
			done <<< "$active"

		else
		
			statusmsg "Multiswitch - " "white" "Inaktiv" "grey" "" "" "Kein Multiswitch definiert" "white"
		
		fi
		
	else

		if test -f "$service_file"; then
			
			if_state=$(cat $service_file | grep "multiswitch service" | awk '{ printf "["$6"]" }')
			then_state=$(cat $service_file | grep "multiswitch service" | awk '{ printf "["$7"]" }')
																						
			statusmsg "Multiswitch - " "white" "$desc_dev1: " "hotpink" "Aktiv" "green" "<font color='hotpink'>$desc_dev2</font> $then_state <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> $if_state" "white"
			
		else 
			
			statusmsg "Multiswitch - " "white" "$desc_dev1: " "hotpink" "Inaktiv" "grey" "<font color='hotpink'>$desc_dev2</font> [$value2] <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> [$value1]" "white"

		fi

		exit 1
	fi
fi

# add multiswitch
if [ "$1" = "add" ]; then

	if [ "$dev1" = "$dev2" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Unterschiedliche Geräte auswählen" "white"
		
		exit 1
	
	fi

	if [ -z "$value1" ] || [ -z "$value2" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Zu wenig Parameter definiert \n Usage: multiswitch show|add|remove dev1 dev2 value1 value2" "white"
		
		exit 1
	fi

	if test -f "$service_file"; then
		
		statusmsg "Multiswitch - " "white" "$desc_dev1: " "hotpink" "Aktiv" "green" "<font color='hotpink'>$desc_dev2</font> [$value2] <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> [$value1]" "white"

	else
	
		cp $service_template $service_file

		sed -i "s/-dev1/$dev1/" $service_file
		sed -i "s/-dev2/$dev2/" $service_file
		sed -i "s/-value1/$value1/" $service_file
		sed -i "s/-value2/$value2/" $service_file

		systemctl start $service_name
		systemctl enable $service_name
		
		statusmsg "Multiswitch - " "white" "$desc_dev1: " "hotpink" "Aktiviert" "green" "<font color='hotpink'>$desc_dev2</font> [$value2] <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> [$value1]" "white"

	fi
fi

# remove multiswitch
if [ "$1" = "remove" ]; then

	if [ "$dev1" = "$dev2" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Unterschiedliche Geräte auswählen" "white"

		exit 1
	
	fi

	systemctl stop $service_name
	systemctl disable $service_name

	rm -r $service_file
	
	statusmsg "Multiswitch - " "white" "$desc_dev1: " "hotpink" "Deaktiviert" "grey" "<font color='hotpink'>$desc_dev2</font> [$value2] <font color='grey'>wenn</font> <font color='hotpink'>$desc_dev1</font> [$value1]" "white"

	exit 1
fi

# service mode
if [ "$1" = "service" ]; then
	
	lastvalue=""
	
	while read curvalue;
	do
		echo "last: $curvalue"
		
		if [ "$curvalue" = "$lastvalue" ]; then
			
			echo "$dev1 <$curvalue>: Nothing changed"
			lastvalue=""
			
		elif [ "${curvalue^^}" = "${value1^^}" ]; then
		
			mosquitto_pub -h $server -u $user -P $pass -t $dev2_control_topic -m $value2
			echo "$dev1 <$curvalue> -> $dev2: <$value2>"
			lastvalue="$curvalue"
			
		else
		
			echo "$dev1 <$curvalue>: Nothing todo"
			lastvalue="none"
			
		fi
	
	done < <(mosquitto_sub -h $server -u $user -P $pass -t $dev1_power_topic -q 2)

fi