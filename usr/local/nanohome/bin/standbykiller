#!/bin/bash
# standbykiller for NanoHome - sends OFF to topic if device falls below [W]

# Catch Parameters
device="$2"
maxpower="$3"

# device support
if [ ! "$device" = "all" ]; then
	. /usr/local/nanohome/dev_compatibility $device
fi

# environment
service_description="standbykiller"
service_name="$service_description.$device.service"
service_file="/etc/systemd/system/$service_name"
service_template="/usr/local/nanohome/templates/$service_description.service.template"

# functions

get_status () {

	# make parameters readable on dashboard
	if [[ "$status" =~ "running" ]]; then
		color="#c0fcb1"
		statmsg="aktiv"
	else
		color="grey"
		statmsg="inaktiv"
	fi

}

#/////////////////////////////////////////////////////////////////////////////////////
# Print Standbykiller and their Cronjobs On Dashboard
#/////////////////////////////////////////////////////////////////////////////////////
print_killer () {

	dev="$1"
	condition="$2"
	service_name="$3"

	if [[ "$status" =~ "Aktiv" ]]; then
	 	color="#c0fcb1"
	 else
	 	color="grey"
	 fi

	desc="$(cat /usr/local/nanohome/devlist | grep $dev | cut -d: -f2 )"
	
	echo "<font size='4' color='hotpink'>$desc</font>"

	if [ ! -z "$service_name" ]; then

		status="$(systemctl status $service_name | head -3 | tail -1 | awk '{ print $2 " " $3 " " $4 " " $6 " " $7 }')"
		lastmsg="$(systemctl status $service_name | tail -5 | sort -r | grep '|' | cut -d'|' -f 2 )"

		if [[ "$status" =~ "running" ]]; then
			statuscolor="#c0fcb1"
		else
			statuscolor="grey"
		fi
		
		echo ""
		echo "<font size='3' color='$statuscolor'>$condition</font>"
		echo ""
		echo "<font size='3'>Last Messages:</font>"
		echo "<font size='2'>$lastmsg</font>"
		echo ""

	else
		status="inaktiv"
		lstmsg=""
	fi

}

# show devices
if [ "$1" = "show" ] && [ ! -z "$device" ]; then

	# show all devices
	if [ "$device" = "all" ]; then

		active="$(ls /etc/systemd/system/ | grep standbykiller )"

		if [ ! -z "$active" ]; then
			
			echo "<font size='5' color='white'>Standbykiller</font><font size='5' color='#c0fcb'> aktiv</font><br>"
			
			while IFS= read -r line
			do

				dev="$( grep ExecStart /etc/systemd/system/$line | awk '{ printf $3 }' )"
				maxpower="$( grep ExecStart /etc/systemd/system/$line | awk '{ printf $4 }' )"
				devdesc="$(cat /usr/local/nanohome/devlist | grep $dev | cut -d: -f2 )"
				msg="Aktiv wenn unter ${maxpower}W"

				print_killer "$devdesc" "$msg"

			done <<< "$active"

		else

			statusmsg "Standbykiller " "white" " Inaktiv" "grey" "Kein Standbykiller definiert" "grey"

		fi

	# show active state of specific device
	elif test -f "$service_file"; then

		maxpower="$( grep ExecStart /etc/systemd/system/$service_name | awk '{ printf $4 }' )"
		msg="Aktiv wenn unter ${maxpower}W"
		
		echo "<font size='5' color='white'>Standbykiller</font><font size='5' color='#c0fcb'> aktiv</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	# show insctive state of specific device
	else
		
		echo "<font size='5' color='white'>Standbykiller</font><font size='5' color='grey'> inaktiv</font><br>"
		
		print_killer "$dev_desc" "inaktiv"

	fi

# add device
elif [ "$1" = "add" ] && [ ! -z "$device" ] && [ ! -z "$maxpower" ]; then

	# check if service exists
	if test -f "$service_file"; then

		msg="Aktiv wenn unter ${maxpower}W" 
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	# create new service
	else

		cp $service_template $service_file

		sed -i "s/-dev/$device/" $service_file
		sed -i "s/-sbpwr/$maxpower/" $service_file

		systemctl start $service_name
		systemctl enable $service_name

		msg="Aktiviert wenn unter ${maxpower}W"
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	fi

# remove device
elif [ "$1" = "remove" ] && [ ! -z "$device" ]; then

	systemctl stop $service_name
	systemctl disable $service_name

	rm -r $service_file
	
	echo "<font size='5' color='white'>Standbykiller</font><br>"
	
	print_killer "$dev_desc" "Deaktiviert"

else

	echo "----------------------------------------------------------"
	echo "Usage: standbykiller show|add|remove device (standbypower)"
	echo "----------------------------------------------------------"
	echo

	exit 1

fi
