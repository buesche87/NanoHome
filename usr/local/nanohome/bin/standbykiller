#!/bin/bash
# Standbykiller - sends OFF to topic if device falls below [W]

if [ -z "$1" ] || [ -z "$2" ]; then

	echo "----------------------------------------"
	echo "Usage: standbykiller device standbypower"
	echo "----------------------------------------"
	echo

	exit 1
fi

# settings
server="localhost"
user="cron_mqtt"
pass="Cron2MQTT"

# Parameters
device="$2"
maxpower="$3"

# device support
. /usr/local/nanohome/dev_compatibility $device
dev=$(cat /usr/local/nanohome/devlist | grep $device | cut -d: -f2 )

# environment
command="off"
service_name="standbykiller.$device.service"
service_file="/etc/systemd/system/$service_name"
service_template="/usr/local/nanohome/templates/standbykiller.service.template"
show_stby=$(cat $service_file | grep "standbykiller service $device" | awk '{ printf $5"\n" }')

# show devices
if [ "$1" = "show" ]; then

	if [ "$device" = "all" ]; then
		
		# -------- To be done ---------#
		
		active="$(ls /etc/systemd/system/ | grep standbykiller )"
		
		if [ ! -z "$active" ]; then
		
			echo "<font size='6' color='white'>Standbykiller - </font><font size='6' color='green'>Aktiv:</font><br>"
			
			while IFS= read -r line
			do
				
				dev="$(cat /etc/systemd/system/$line | grep standbykiller | awk '{ printf $4 }' )"
				val="$(cat /etc/systemd/system/$line | grep standbykiller | awk '{ printf $5 }' )"
				
				desc_dev=$(cat /usr/local/nanohome/devlist | grep $dev | cut -d: -f2 )
				
				echo "<font color='hotpink'>$desc_dev</font> @ [${val}W]"
				
			done <<< "$active"
		
		else
		
			statusmsg "Standbykiller - " "white" "Inaktiv" "grey" "" "" "Kein Standbykiller definiert" "white"
		
		fi
		
		
	elif test -f "$service_file"; then
		
		statusmsg "Standbykiller - " "white" "$dev: " "hotpink" "Aktiv [${show_stby}W]" "green"

	else
		
		statusmsg "Standbykiller - " "white" "$dev: " "hotpink" "Inaktiv" "grey"

	fi

	exit 1

fi

# add device
if [ "$1" = "add" ]; then

	if [ "$2" = "all" ]; then
		
		
		statusmsg "Error" "red" "" "" "" "" "Alle aktivieren nicht unterstützt" "white"
		
		exit 1
	fi

	if test -f "$service_file"; then
		
		statusmsg "Standbykiller - " "white" "$dev: " "hotpink" "Aktiv [${maxpower}W]" "green"
	
	else
	
		cp $service_template $service_file

		sed -i "s/-dev/$device/" $service_file
		sed -i "s/-sbpwr/$maxpower/" $service_file

		systemctl start $service_name
		systemctl enable $service_name
		
		statusmsg "Standbykiller - " "white" "$dev: " "hotpink" "Aktiviert [${maxpower}W]" "green"

	fi
fi

# remove device
if [ "$1" = "remove" ]; then
	
	if [ "$2" = "all" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Alle deaktivieren nicht unterstützt" "white"
		
		exit 1
	fi
	
	systemctl stop $service_name
	systemctl disable $service_name

	rm -r $service_file
	
	statusmsg "Standbykiller - " "white" "$dev: " "hotpink" "Deaktiviert" "grey"
	
	exit 0
fi

# service mode
if [ "$1" == "service" ]; then

	lastmsg="off"

	while read curpower;
	do

		now=$(date +"%T")

		if (( $(echo "$curpower == 0" | bc -l) )); then

			echo "[$now] $device: off"
			lastmsg="off"

		elif (( $(echo "$curpower < $maxpower" | bc -l) )); then

			if [ "$lastmsg" == "off" ]; then

				echo "[$now] $device just started, wait 5 Minutes"

				sleep 5
			else

				echo "[$now] $device: ${curpower}W, less than ${maxpower}W - killing standby"
				echo "$server $user $pass $control_topic $command"
				mosquitto_pub -h $server -u $user -P $pass -t $control_topic -m $command >/dev/null 2>&1
			fi

		else
			echo "[$now] $device: ${curpower}W, more than ${maxpower}W - keeping Alive"
			lastmsg="running"
		fi

	done < <(mosquitto_sub -h $server -u $user -P $pass -t $power_topic -q 2)

fi
