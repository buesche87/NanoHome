#!/bin/bash
# standbykiller for NanoHome - sends OFF to topic if device falls below [W]

# settings
server="localhost"
user="cron_mqtt"
pass="Cron2MQTT"

# Parameters
device="$2"
maxpower="$3"

# device support
if [ ! "$device" = "all" ]; then
	. /usr/local/nanohome/dev_compatibility $device
fi

# environment
service_description="standbykiller"
service_name="$service_description.$device.service"
service_file="/etc/systemd/system/$service_name"
service_template="/usr/local/nanohome/templates/$service_description.service.template"

# functions
print_killer () {

	dev="$1"
	status="$2"
	service_name="$3"

	if [[ "$status" =~ "Aktiv" ]]; then
		color="#c0fcb1"
	else
		color="grey"
	fi

	desc="$(cat /usr/local/nanohome/devlist | grep $dev | cut -d: -f2 )"
	
	echo "<font size='4'><font color='hotpink'>$desc</font>: <font color='$color'>$status</font></font>"

	if [ ! -z "$service_name" ]; then

		status="$(systemctl status standbykiller.shelly1pm-76DAD6.service | head -3 | tail -1 | awk '{ print $2 " " $3 " " $4 " " $6 " " $7 }')"
		lastmsg="$(systemctl status $service_name | tail -5 | sort -r | grep '|' | cut -d'|' -f 2 )"

		if [[ "$status" =~ "running" ]]; then
			statuscolor="#c0fcb1"
		else
			statuscolor="grey"
		fi
		
		echo ""
		echo "<font size='3' color='$statuscolor'>$status</font>"
		echo ""
		echo "<font size='3'>Last Messages:</font>"
		echo "<font size='2'>$lastmsg</font>"
		echo ""

	else
		status="Inaktiv"
		lstmsg=""
	fi

}

# show devices
if [ "$1" = "show" ] && [ ! -z "$device" ]; then

	# show all devices
	if [ "$device" = "all" ]; then

		active="$(ls /etc/systemd/system/ | grep standbykiller )"

		if [ ! -z "$active" ]; then
			
			echo "<font size='5' color='white'>Standbykiller</font><br>"
			
			while IFS= read -r line
			do

				dev="$(cat /etc/systemd/system/$line | grep standbykiller | awk '{ printf $4 }' )"
				maxpower="$(cat /etc/systemd/system/$line | grep standbykiller | awk '{ printf $5 }' )"
				devdesc="$(cat /usr/local/nanohome/devlist | grep $dev | cut -d: -f2 )"
				msg="Aktiv wenn unter ${maxpower}W"

				print_killer "$devdesc" "$msg"

			done <<< "$active"

		else

			statusmsg "Standbykiller " "white" "" "" "Inaktiv - Kein Standbykiller definiert" "grey"

		fi

	# show active state of specific device
	elif test -f "$service_file"; then

		maxpower="$(cat $service_file | grep "standbykiller service $device" | awk '{ printf $5"\n" }')"
		msg="Aktiv wenn unter ${maxpower}W"
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	# show insctive state of specific device
	else
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "Inaktiv"

	fi

# add device
elif [ "$1" = "add" ] && [ ! -z "$device" ] && [ ! -z "$maxpower" ]; then

	# check if service exists
	if test -f "$service_file"; then

		msg="Aktiv wenn unter ${maxpower}W" 
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	# create new service
	else

		cp $service_template $service_file

		sed -i "s/-dev/$device/" $service_file
		sed -i "s/-sbpwr/$maxpower/" $service_file

		systemctl start $service_name
		systemctl enable $service_name

		msg="Aktiviert wenn unter ${maxpower}W"
		
		echo "<font size='5' color='white'>Standbykiller</font><br>"
		
		print_killer "$dev_desc" "$msg" "$service_name"

	fi

# remove device
elif [ "$1" = "remove" ] && [ ! -z "$device" ]; then

	systemctl stop $service_name
	systemctl disable $service_name

	rm -r $service_file
	
	echo "<font size='5' color='white'>Standbykiller</font><br>"
	
	print_killer "$dev_desc" "Deaktiviert"

# service mode
elif [ "$1" == "service" ]; then

	lastmsg="off"
	try="1"

	while read curpower;
	do

		now=$(date +"%T")

		if (( $(echo "$curpower == 0" | bc -l) )); then

			echo "|[$now] $device: off -> nothing todo"
			lastmsg="off"

		elif (( $(echo "$curpower < $maxpower" | bc -l) )); then

			if [ "$lastmsg" == "off" ]; then

				echo "|[$now] $device just started -> I won't kill it yet"

			elif [ try > 2 ]; then #give time to manually wake unwanted standby
			
				echo "|[$now] $device: ${curpower}W - standby killed"

				mosquitto_pub -h $server -u $user -P $pass -t $control_topic -m $off_command >/dev/null 2>&1			

			else
				
				echo "|[$now] $device: ${curpower}W - less than ${maxpower}W -> wait 60s and then kill standby"
				((try=try+1))

			fi

		else
			echo "|[$now] $device: ${curpower}W - more than ${maxpower}W -> keeping alive"
			lastmsg="running"
		fi

	done < <(mosquitto_sub -h $server -u $user -P $pass -t $power_topic -q 2)

else

	echo "----------------------------------------------------------"
	echo "Usage: standbykiller show|add|remove device (standbypower)"
	echo "----------------------------------------------------------"
	echo

	exit 1

fi
