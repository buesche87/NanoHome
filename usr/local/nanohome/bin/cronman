#!/bin/bash
# cronman - manages switches with crontab

if [ -z "$1" ] || [ -z "$2" ]; then

		echo "--------------------------------------------------------------"
		echo "Usage: cronman show|add|remove device|all (on_time) (off_time)"
		echo "--------------------------------------------------------------"
		echo

		exit 1
fi

# parameter
device="$2"
dev_desc="$(cat /usr/local/nanohome/devlist | grep $device | cut -d: -f2 )"

# settings
server="localhost"
user="cron_mqtt"
pass="Cron2MQTT"

# device support
. /usr/local/nanohome/dev_compatibility $device
topic=$(echo $power_topic)

# functions
get_dev () {

	# Zu prüfendes Gerät definieren
	check_dev="$1"
	print="$2"
	
	# Geräte mit aktiver Schaltuhr suchen
	aktive_zsp="$(crontab -l | grep mosquitto | awk '{ printf $14"\n" }'  | awk '!NF || !seen[$0]++' | awk -F'/' '{print $2}')"
	
	while IFS= read -r line
	do		
		if [ "$check_dev" = "all" ] || [ "$check_dev" = "$line" ]; then
			
			curdev="$line"
			
			if [ "$print" = "yes" ]; then			
				show_zsp "$curdev" 
			fi

		fi
	done < <(printf '%s\n' "$aktive_zsp")

}

show_zsp () {
	
	curdev="$1"
	dev=$(cat /usr/local/nanohome/devlist | grep $curdev | cut -d: -f2 )
	
	echo "<font size=6 color='white'>Schaltuhr - <font color='hotpink'>$dev: </font></font><font size=6 color='green'>Aktiv</font><br><font size=5 color='white'>"
	
	zsp=$(crontab -l | grep $curdev)

	while IFS= read -r line
	 do
		
		dev_state_temp=$(printf '%s\n' "$line" | awk '{ printf $5 ": " $2 ":" $1 " | " $16 } ')
		dev_state=$(echo $dev_state_temp | sed 's/^*: /Täglich: /g' | sed 's/^1: /Montag: /g' | sed 's/^2: /Dienstag: /g' | sed 's/^3: /Mittwoch: /g' | sed 's/^4: /Donnerstag: /g' | sed 's/^5: /Freitag: /g' | sed 's/^6: /Samstag: /g' | sed 's/^0: /Sonntag: /g' | sed 's/^6-7: /Wochenende: /g' | sed 's/^1-5: /Werktags: /g' | sed 's/ | on/ | Ein/g' | sed 's/ | off/ | Aus/g')
		
		echo "$dev_state"

	done < <(printf '%s\n' "$zsp")	
	
	echo "</font><hr style='border-top: dotted 1px;' />"
	echo

}

# add timer
if [ "$1" = "add" ]; then

	if [ "$device" = "all" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Nur ein Gerät auswählen" "white"
		
		exit 1
	
	fi	

	if [ -z "$3" ] || [ -z "$4" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Zu wenig Parameter definiert \nUsage: cronman show|add|remove device|all shedule (on_time) (off_time)" "white"

        exit 1
		
	elif [ "$4" = "-" ] && [ "$5" = "-" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Das geht nicht" "white"
		
		exit 1
		
	fi

	# Wochentag
	day="$3"
	
	# ON /OFF Zeitpunkte
	on="$4"
	off="$5"

	# Split & Trennzeichen filtern
	on_hour="${on:0:2}"
	on_min="${on:3:5}"
	off_hour="${off:0:2}"
	off_min="${off:3:5}"

	# Cronjob definieren
	zsp_on="$on_min $on_hour * * $day mosquitto_pub -h $server -u $user -P $pass -t $topic -m on"
	zsp_off="$off_min $off_hour * * $day mosquitto_pub -h $server -u $user -P $pass -t $topic -m off"
	
	# Debug
	# echo "$zsp_on"
	# echo "$zsp_off"
	
	onlen=$(echo -n $on | wc -m)
	oflen=$(echo -n $off | wc -m)
	
	# Cronjob eintragen
	if [ $onlen -eq 5 ]; then
		(crontab -l ; echo "$zsp_on") | crontab -
	fi	
	
	if [ $oflen -eq 5 ]; then
		(crontab -l ; echo "$zsp_off") | crontab -
	fi

	# Schaltuhr ausgeben
	get_dev "$device" "yes"
	
fi

# remove timer
if [ "$1" = "remove" ]; then

	if [ "$device" == "all" ]; then
		
		statusmsg "Error" "red" "" "" "" "" "Mehrere löschen nicht möglich" "white"

        exit 1
	fi
		
	get_dev "$device" "no"
	curdev = "$?"
	
	if [ "$device" == "" ]; then
				
		statusmsg "Schaltuhr " "white" "Inaktiv" "grey"

        exit 1
	
	fi

	# Cronjob entfernen
	
	# dev_desc=$(cat /usr/local/nanohome/devlist | grep $devive | cut -d: -f2 )
	statusmsg "Schaltuhr - " "white" "$dev_desc: " "hotpink" "Deaktiviert" "grey" 
	
	
	crontab -l | grep -v "$curdev" | crontab -

fi

# show timer
if [ "$1" = "show" ]; then
	
	if crontab -l | grep cron_mqtt 1> /dev/null 2>&1; then
	
		if [ ! -z "$topic" ] || [ "$device" = "all" ]; then

			get_dev "$device" "yes"

			if [ "$curdev" == "" ]; then

				dev=$( cat /usr/local/nanohome/devlist | grep $curdev | cut -d: -f2 )
			
				statusmsg "Schaltuhr - " "white" "$dev_desc: " "hotpink" "Inaktiv" "grey" 

				exit 1
		
			fi
		fi	
	
	else
		
	statusmsg "Schaltuhr - " "white" "Inaktiv" "grey" "" "" "Es wurde keine Schaltuhr definiert" "white"

	exit 1
	
	fi

fi
