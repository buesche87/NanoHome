#!/bin/bash
# devmgmt - Manages MQTT devices on Grafana Dashboards

if [ -z "$1" ] || [ -z "$2" ]; then
	
	echo "---------------------"
	echo "Zu wenig Argumente"
	echo "---------------------"
	
	exit 1
fi

# Parameter
sn="$2"
device="$3"
devicetype="$4"
bezeichnung="$5"
random="$(date +%s)"

# Settings
home_uid="XieEaLmRk"
devmgr_uid="Uhzl9yRgk"
zsp_uid="_H3fwdmRz"
settings_uid="sYOGRUiRz"
api_key="eyJrIjoiWk9YZDVmbGhRMkpmYjdsT3h3VjhSVjR5cXlwZUh1d3MiLCJuIjoiY3JlYXRlX2VsZW1lbnRzIiwiaWQiOjF9"
template_folder="/usr/local/nanohome/templates"

# Functions
get_dashboard () {
	
	uid="$1"
	curl -X GET -H "Authorization: Bearer $api_key" -H "Content-Type: application/json" http://localhost:3001/api/dashboards/uid/"$uid" > /tmp/merge_panel_temp.json
}

add_json_options () {

	folderid="$(cat /tmp/merge_panel_output.json | grep folderId | awk '{ sub(/^[ \t]+/, ""); print }')"
	json_data="{ ${folderid} \"overwrite\": true }"

	jq --argjson options "$json_data" '. += $options' /tmp/merge_panel_output.json > /tmp/merge_panel_final.json
}

update_dashboard () {

	curl -X POST --insecure -H "Authorization: Bearer $api_key" -H "Content-Type: application/json" -d @/tmp/merge_panel_final.json http://localhost:3001/api/dashboards/db
}



# Main

if [ "$1" = "add" ]; then

	if [ -z "$3" ] || [ -z "$4" ] || [ -z "$5" ]; then
	
		echo "---------------------"
		echo "Zu wenig Argumente"
		echo "---------------------"
	
		exit 1
	fi

	# get devicemanager dashboard & make it readable
	get_dashboard "$devmgr_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json

	# Add new option to dropdown
	sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'.nnao.lan\\">'$bezeichnung'</option>\\r\\n#g' /tmp/merge_panel_output.json

	add_json_options
	update_dashboard

	# Cleanup
	rm /tmp/merge_panel_*


	# add button to home panel if device is a switch
	if [ "$devicetype" == "switch" ]; then
		
		# create new button from template
		cp $template_folder"/"$device"_switch.json.template" "/tmp/merge_panel_input.json"

		sed -i "s/_DEVID_/"$sn"/g"  /tmp/merge_panel_input.json
		sed -i "s/_DESCRIPTION_/"$bezeichnung"/g"  /tmp/merge_panel_input.json
		sed -i "s/_RAND_/"$random"/"  /tmp/merge_panel_input.json
		
		get_dashboard "$home_uid"

		# merge new Button into Dashboard
		jq --argjson panel "$(</tmp/merge_panel_input.json)" '.dashboard.panels += [$panel]' /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		add_json_options
		
		update_dashboard
		
		# Cleanup
		rm /tmp/merge_panel_*
		
		## Schaltuhr


		# Get ZSP Dashboard & make it readable
		get_dashboard "$zsp_uid"
		jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		
		# Add new option to dropdown
		sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'\\">'$bezeichnung'</option>\\r\\n#g' /tmp/merge_panel_output.json
		
		add_json_options
		update_dashboard
		
		# Cleanup
		rm /tmp/merge_panel_*
		
		
		# Get Settings Dashboard & make it readable
		get_dashboard "$settings_uid"
		jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		
		# Add new option to dropdown
		sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'\\">'$bezeichnung'</option>\\r\\n#g' /tmp/merge_panel_output.json
		
		add_json_options
		update_dashboard
		
		# Cleanup
		rm /tmp/merge_panel_*
		
	fi
	
	# Message
	echo "<p>"
	echo "Gerät hinzugefügt"
	
fi

if [ "$1" = "remove" ]; then
	
	echo "TBD"
	
	bezeichnung="$3"
	
	# get devicemanager dashboard & make it readable
	get_dashboard "$devmgr_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json

	# Remove option from dropdown
	sed -i 's#<option value=\\"http://'$sn'.nano.lan\\">'$bezeichnung'</option>\\r\\n##g' /tmp/merge_panel_output.json

	add_json_options
	update_dashboard		

	# Cleanup
	rm /tmp/merge_panel_*


	# Get ZSP Dashboard & make it readable
	get_dashboard "$zsp_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
	
	# Add new option to dropdown
	sed -i 's#<option value=\\"'$sn'\\">'$bezeichnung'</option>\\r\\n##g' /tmp/merge_panel_output.json
	
	<option value=\"TEMP\">TEMP</option>\r\n
	
	add_json_options
	update_dashboard
	
	
	# Cleanup
	rm /tmp/merge_panel_*

	# Get Settings Dashboard & make it readable
	get_dashboard "$settings_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
	
	# Add new option to dropdown
	sed -i 's#<option value=\\"'$sn'\\">'$bezeichnung'</option>\\r\\n##g' /tmp/merge_panel_output.json
	
	add_json_options
	update_dashboard
	
	# Cleanup
	rm /tmp/merge_panel_*
	
	echo "<p>"
	echo "Gerät entfernt"
	echo "<br>"
	echo "Button auf Home manuell löschen"

fi

