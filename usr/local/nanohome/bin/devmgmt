#!/bin/bash
# devmgmt - manages MQTT devices on grafana dashboards

if [ -z "$1" ]; then
	
	echo "----------------------------------------------------------"
	echo "Zu wenig Argumente"
	echo "Usage: devmgmt add|remove sn description device devicetype"
	echo "----------------------------------------------------------"
	echo
	
	exit 1
	
fi

# parameter
sn="$2"
desc="$3"
device="$4"
devicetype="$5"
random="$(date +%s)"

# settings
home_uid="XieEaLmRk"
devmgr_uid="Uhzl9yRgk"
zsp_uid="_H3fwdmRz"
settings_uid="sYOGRUiRz"
api_key="eyJrIjoiWk9YZDVmbGhRMkpmYjdsT3h3VjhSVjR5cXlwZUh1d3MiLCJuIjoiY3JlYXRlX2VsZW1lbnRzIiwiaWQiOjF9"
template_folder="/usr/local/nanohome/templates"

# functions
get_dashboard () {
	
	uid="$1"
	curl -X GET -H "Authorization: Bearer $api_key" -H "Content-Type: application/json" http://localhost:3001/api/dashboards/uid/"$uid" > /tmp/merge_panel_temp.json
}

add_json_options () {

	folderid="$(cat /tmp/merge_panel_output.json | grep folderId | awk '{ sub(/^[ \t]+/, ""); print }')"
	json_data="{ ${folderid} \"overwrite\": true }"

	jq --argjson options "$json_data" '. += $options' /tmp/merge_panel_output.json > /tmp/merge_panel_final.json
}

update_dashboard () {

	curl -X POST --insecure -H "Authorization: Bearer $api_key" -H "Content-Type: application/json" -d @/tmp/merge_panel_final.json http://localhost:3001/api/dashboards/db
}

err_exit () {
	
	statusmsg "Error" "red" "" "" "" "" "Zu wenig Parameter definiert \nUsage: devmgmt add|remove sn description device devicetype" "white"
	
	exit 1
}

# show devices
if [ "$1" = "show" ]; then
	
	msg=$(cat /usr/local/nanohome/devlist | awk -F':' '{printf "<font color='hotpink'>"$2 ":</font> " $1 "<br>"}')

	statusmsg "Geräteliste" "white" "" "" "" "" "$msg" "white"

	exit 0
	
fi

# add device
if [ "$1" = "add" ]; then

	if  [ -z "$2" ] || [ -z "$3" ] || [ -z "$4" ] || [ -z "$5" ]; then
	
		err_exit
		
	fi
	
	# add device to devlist
	echo -e "\n$sn:$desc" >> /usr/local/nanohome/devlist
	
	# get devicemanager dashboard & make it readable
	get_dashboard "$devmgr_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json

	# add new option to dropdown
	sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'.nnao.lan\\">'$desc'</option>#g' /tmp/merge_panel_output.json

	add_json_options
	update_dashboard

	# cleanup
	rm /tmp/merge_panel_*


	# add specific elements if device is a switch
	if [ "$devicetype" == "switch" ]; then
		
		## button on home dashboard
		# create new button from template
		cp $template_folder"/"$device"_switch.json.template" "/tmp/merge_panel_input.json"

		sed -i "s/_DEVID_/"$sn"/g"  /tmp/merge_panel_input.json
		sed -i "s/_DESCRIPTION_/"$desc"/g"  /tmp/merge_panel_input.json
		sed -i "s/_RAND_/"$random"/"  /tmp/merge_panel_input.json
		
		get_dashboard "$home_uid"

		# merge new Button into Dashboard
		jq --argjson panel "$(</tmp/merge_panel_input.json)" '.dashboard.panels += [$panel]' /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		add_json_options
		
		update_dashboard
		
		# cleanup
		rm /tmp/merge_panel_*
		
		
		## dropdown on timer dashboard
		# get timer dashboard & make it readable
		get_dashboard "$zsp_uid"
		jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		
		# add new option to dropdown
		sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'\\">'$desc'</option>#g' /tmp/merge_panel_output.json
		
		add_json_options
		update_dashboard
		
		# cleanup
		rm /tmp/merge_panel_*
		
		## dropdowns in ettings dashboard
		# Ggt Settings Dashboard & make it readable
		get_dashboard "$settings_uid"
		jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
		
		# add new option to dropdown
		sed -i 's#name=\\"nanolist\\">#name=\\"nanolist\\">\\r\\n<option value=\\"'$sn'\\">'$desc'</option>#g' /tmp/merge_panel_output.json
		
		add_json_options
		update_dashboard
		
		# cleanup
		rm /tmp/merge_panel_*
		
	fi
	
	# message
	
	statusmsg "Device Manager" "white" "$desc:" "hotpink" " Gerät $sn hinzugefügt" "white"
	
	exit 0
	
fi

# remove device
if [ "$1" = "remove" ]; then
	
	if  [ -z "$2" ] || [ -z "$3" ]; then
	
		err_exit
		
	fi
	
	# remove device from devlist
	sed -i '/'$sn'/d' /usr/local/nanohome/devlist
	
	## remove from device manager dashboard
	# get devicemanager dashboard & make it readable
	get_dashboard "$devmgr_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json

	# remove option from dropdown
	sed -i 's#<option value=\\"'$sn'.nano.lan\\">'$desc'</option>\\r\\n##g' /tmp/merge_panel_output.json

	add_json_options
	update_dashboard		

	# cleanup
	rm /tmp/merge_panel_*

	## remove from timer dashboard
	# get timer dashboard & make it readable
	get_dashboard "$zsp_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
	
	# remove option from dropdown
	sed -i 's#<option value=\\"'$sn'\\">'$desc'</option>\\r\\n##g' /tmp/merge_panel_output.json
	
	<option value=\"TEMP\">TEMP</option>\r\n
	
	add_json_options
	update_dashboard

	# cleanup
	rm /tmp/merge_panel_*

	## remove from settings dashboard
	# get settings dashboard & make it readable
	get_dashboard "$settings_uid"
	jq . /tmp/merge_panel_temp.json > /tmp/merge_panel_output.json
	
	# remove option to dropdown
	sed -i 's#<option value=\\"'$sn'\\">'$desc'</option>\\r\\n##g' /tmp/merge_panel_output.json
	
	add_json_options
	update_dashboard
	
	# cleanup
	rm /tmp/merge_panel_*
	
	# message
	
	statusmsg "Device Manager" "white" "$desc:" "hotpink" " Gerät $sn gelösch\nButton auf Home manuell löschent" "white"
	
	exit 0

fi